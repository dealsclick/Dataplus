{
  "name": "dataplus",
  "version": "0.1.0",
  "private": true,
  "description": "Local MVP for managing marketplace inventory and orders.",
  "scripts": {
    "start": "node server.js",
    "worker": "node scripts/dataplus-worker.js",
    "worker:once": "node -e \"process.env.DATAPLUS_WORKER_ONCE='1'; require('./scripts/dataplus-worker')\"",
    "web:build": "npm --prefix web run build",
    "web:dev": "npm --prefix web run dev",
    "db:migrate": "node scripts/migrate-json-to-postgres.js",
    "import:product-dump": "node scripts/import-product-dump.js",
    "import:shopify-taxonomy": "node scripts/import-shopify-taxonomy.js",
    "catalog:index": "node scripts/build-source-catalog-index.js",
    "catalog:rehydrate-products": "node scripts/rehydrate-products-from-catalog.js",
    "shopify:truevalue-variation-dry-run": "node scripts/truevalue-variation-repair-dry-run.js",
    "shopify:truevalue-variation-repair": "node scripts/truevalue-variation-repair-apply.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "basic-ftp": "^5.3.0",
    "bson": "^7.2.0",
    "pg": "^8.20.0"
  }
}
